{
  "redirects": [
    { "source": "/cases-hub",              "destination": "/cases",         "permanent": true },
    { "source": "/cases-hub/eforce",       "destination": "/eforce",        "permanent": true },
    { "source": "/cases-hub/adash",        "destination": "/adash",         "permanent": true },
    { "source": "/cases-hub/design",       "destination": "/design",        "permanent": true },
    { "source": "/cases-hub/design/:slug", "destination": "/design/:slug",  "permanent": true }
  ],
  "rewrites": [
    { "source": "/adash-demo/(.*)", "destination": "/adash-demo/$1" },
    { "source": "/adash-demo",      "destination": "/adash-demo/index.html" },
    { "source": "/adash/(.*)",      "destination": "/cases-hub/adash/$1" },
    { "source": "/adash",           "destination": "/cases-hub/adash/index.html" },
    { "source": "/eforce/(.*)",     "destination": "/cases-hub/eforce/$1" },
    { "source": "/eforce",          "destination": "/cases-hub/eforce/index.html" },
    { "source": "/design/alba/(.*)",        "destination": "/cases-hub/design/alba/$1" },
    { "source": "/design/alba",             "destination": "/cases-hub/design/alba/index.html" },
    { "source": "/design/arvo/(.*)",        "destination": "/cases-hub/design/arvo/$1" },
    { "source": "/design/arvo",             "destination": "/cases-hub/design/arvo/index.html" },
    { "source": "/design/atelier-norr/(.*)", "destination": "/cases-hub/design/atelier-norr/$1" },
    { "source": "/design/atelier-norr",     "destination": "/cases-hub/design/atelier-norr/index.html" },
    { "source": "/design/lumenform/(.*)",   "destination": "/cases-hub/design/lumenform/$1" },
    { "source": "/design/lumenform",        "destination": "/cases-hub/design/lumenform/index.html" },
    { "source": "/design/meridian/(.*)",    "destination": "/cases-hub/design/meridian/$1" },
    { "source": "/design/meridian",         "destination": "/cases-hub/design/meridian/index.html" },
    { "source": "/design/vektor/(.*)",      "destination": "/cases-hub/design/vektor/$1" },
    { "source": "/design/vektor",           "destination": "/cases-hub/design/vektor/index.html" },
    { "source": "/design/(.*)",             "destination": "/cases-hub/design/$1" },
    { "source": "/design",                  "destination": "/cases-hub/design/index.html" },
    { "source": "/cases/(.*)",      "destination": "/cases-hub/$1" },
    { "source": "/cases",           "destination": "/cases-hub/index.html" },
    { "source": "/blog",            "destination": "/blog/index.html" },
    { "source": "/blog/(.*)",       "destination": "/blog/$1.html" },
    { "source": "/metodo",          "destination": "/metodo.html" },
    { "source": "/manifesto",       "destination": "/manifesto.html" },
    { "source": "/sobre",              "destination": "/sobre.html" },
    { "source": "/processo/adash",     "destination": "/processo/adash.html" },
    { "source": "/processo",           "destination": "/processo/adash.html" },
    { "source": "/vs-agencia",          "destination": "/vs-agencia.html" },
    { "source": "/para/saas",           "destination": "/para/saas.html" },
    { "source": "/para/startups",       "destination": "/para/startups.html" },
    { "source": "/obrigado",            "destination": "/obrigado.html" },
    { "source": "/founder",             "destination": "/founder.html" },
    { "source": "/call",                "destination": "/call.html" },
    { "source": "/en",                  "destination": "/en/index.html" },
    { "source": "/en/about",            "destination": "/en/about.html" },
    { "source": "/en/method",           "destination": "/en/method.html" },
    { "source": "/en/manifesto",        "destination": "/en/manifesto.html" },
    { "source": "/en/cases",            "destination": "/en/cases.html" },
    { "source": "/en/vs-agency",        "destination": "/en/vs-agency.html" },
    { "source": "/en/for/saas",         "destination": "/en/for/saas.html" },
    { "source": "/en/for/startups",     "destination": "/en/for/startups.html" },
    { "source": "/en/thank-you",        "destination": "/en/thank-you.html" },
    { "source": "/en/call",             "destination": "/en/call.html" },
    { "source": "/en/eforce",           "destination": "/en/eforce.html" },
    { "source": "/en/adash",            "destination": "/en/adash.html" },
    { "source": "/en/process/adash",    "destination": "/en/process/adash.html" },
    { "source": "/en/process",          "destination": "/en/process/adash.html" },
    { "source": "/en/blog",             "destination": "/en/blog/index.html" },
    { "source": "/en/blog/(.*)",        "destination": "/en/blog/$1.html" },
    { "source": "/en/design",           "destination": "/en/design.html" }
  ]
}
